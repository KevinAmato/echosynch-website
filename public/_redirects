# Cloudflare Pages redirect rules.
#
# Format: <from>  <to>  <status>
# Pattern lifted from Thread-Patrol's _redirects — strip the .html suffix
# from any direct hits so /privacy and /privacy.html land at the same
# canonical URL. The `format: 'file'` Astro setting emits *.html, so the
# rules go in the OPPOSITE direction here vs. a typical SPA.
#
# 301 (permanent) is correct: search engines should consolidate link
# equity onto the canonical extension-less URL.

/privacy.html        /privacy        301
/terms.html          /terms          301
/dpa.html            /dpa            301
/trust-center.html   /trust-center   301
/support.html        /support        301
/changelog.html      /changelog      301
/docs.html           /docs           301
/index.html          /               301

# www → apex (Cloudflare handles this at DNS level too, but the rule is
# defense-in-depth in case a visitor hits an old www link).
https://www.echo-synch.com/*   https://echo-synch.com/:splat   301
