---
// Site-wide footer. Same on every page so the legal links, status pulse,
// and address are always one click away — Slack Directory review checks
// for these on the landing page specifically.
//
// We deliberately don't embed a newsletter form (Thread-Patrol does — via
// Formspree). Reasons:
//   1. Echo-Synch is B2B, not B2C. The audience converts via demo or trial,
//      not a "tips in your inbox" funnel.
//   2. A newsletter form means another vendor (Formspree → personal data),
//      another DPA, another row in the subprocessor list. Not worth it.
//   3. The "Talk to us" mailto already covers the same intent for the rare
//      visitor who wants async contact.

const year = new Date().getFullYear();
---

<footer class="mk-footer">
  <div class="mk-container">
    <div class="mk-footer-grid">
      <div>
        <a href="/" class="mk-brand">
          <img src="/echo-synch.svg" alt="" width="28" height="28" />
          <span class="mk-brand-name">Echo-<span>Synch</span></span>
        </a>
        <p class="mk-footer-desc">
          IT request triage that lives in Slack. AI summaries, SLA tracking,
          assignee management — without the process tax.
        </p>
      </div>

      <div>
        <h4>Product</h4>
        <ul>
          <li><a href="/#product">How it works</a></li>
          <li><a href="/#pricing">Pricing</a></li>
          <li><a href="/#compare">Compare</a></li>
          <li><a href="/docs">Docs</a></li>
        </ul>
      </div>

      <div>
        <h4>Resources</h4>
        <ul>
          <li><a href="/support">Support &amp; FAQ</a></li>
          <li><a href="/changelog">Changelog</a></li>
          <li><a href="/trust-center">Trust center</a></li>
          <li><a href="mailto:support@echo-synch.com">support@echo-synch.com</a></li>
        </ul>
      </div>

      <div>
        <h4>Legal</h4>
        <ul>
          <li><a href="/privacy">Privacy</a></li>
          <li><a href="/terms">Terms</a></li>
          <li><a href="/dpa">DPA</a></li>
          <li><a href="/trust-center">Subprocessors</a></li>
        </ul>
      </div>
    </div>

    <div class="mk-footer-bottom">
      <span>© {year} Echo-Synch · Made in Italy 🇮🇹</span>
      <span class="mk-footer-status">
        All systems operational
      </span>
    </div>
  </div>
</footer>
