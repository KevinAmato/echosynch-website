---
// Sticky top nav. Single source of truth — every page imports Layout.astro
// which includes this. The `active` prop highlights the current section so
// the nav reflects "where am I" without per-page boilerplate.
//
// IMPORTANT: keep the link list short (4 items max). Adding /docs or /blog
// later is fine; resist adding "Resources", "Use cases", "Solutions" type
// dropdowns — those are growth-marketing instincts that conflict with the
// brand voice (Frictionless · Technical · Quiet).
interface Props {
  active?: 'product' | 'pricing' | 'compare' | 'trust' | null;
}
const { active = null } = Astro.props;

// We deliberately keep /docs OUT of the primary nav until there's real
// docs content — exposing an empty page in the top nav looks broken to
// first-time visitors. /trust-center earns the slot instead because it's
// the page enterprise procurement and Slack Directory reviewers actively
// look for. Docs returns to the nav when we have ≥5 substantive topic
// pages, not before.
const links: { label: string; href: string; key: NonNullable<Props['active']> }[] = [
  { label: 'Product',  href: '/#product',  key: 'product' },
  { label: 'Compare',  href: '/#compare',  key: 'compare' },
  { label: 'Pricing',  href: '/#pricing',  key: 'pricing' },
  { label: 'Trust',    href: '/trust-center', key: 'trust' },
];

// "Add to Slack" CTA goes straight to the bot's OAuth install URL.
// Pre-Marketplace-approval, direct-link installs still work — Slack
// shows a "this app is in development" banner on the consent screen
// but the OAuth flow completes normally. Once approved, the same URL
// continues to work (Slack just adds the green "verified" checkmark
// to the consent screen).
//
// History: this CTA used to open a WaitlistModal that collected an
// email and POST'd to a Resend audience. Removed in April 2026 once
// the bot was production-ready and we wanted to start collecting
// install-data signal that Slack reviews need (5 active workspaces).
---

<header class="mk-nav">
  <div class="mk-nav-inner mk-container">
    <a href="/" class="mk-brand" aria-label="Echo-Synch home">
      <img src="/echo-synch.svg" alt="" width="28" height="28" />
      <span class="mk-brand-name">Echo-<span>Synch</span></span>
    </a>

    <nav class="mk-navlinks" aria-label="Primary">
      {links.map(l => (
        <a href={l.href} class={active === l.key ? 'active' : ''}>{l.label}</a>
      ))}
    </nav>

    <div class="mk-nav-actions">
      <a href="https://app.echo-synch.com" class="mk-nav-signin">Sign in</a>
      <a
        href="https://api.echo-synch.com/slack/install"
        class="mk-btn mk-btn-primary"
      >
        Add to Slack
      </a>
    </div>
  </div>
</header>
