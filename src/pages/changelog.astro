---
// /changelog — public release notes. Stub for now; populates as we ship.
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Changelog — Echo-Synch"
  description="What's new in Echo-Synch — release notes for every shipped change."
>
  <header class="mk-pageheader">
    <div class="mk-container-narrow">
      <p class="mk-eyebrow">Changelog</p>
      <h1 class="mk-display">What's new</h1>
      <p class="mk-lead">
        Every shipped change, in reverse chronological order. We start
        publishing here once the public beta opens.
      </p>
    </div>
  </header>
  <article class="mk-prose">
    <p>Nothing to log publicly yet — Echo-Synch is in private beta.</p>
    <p>Want early access? <a href="mailto:hello@echo-synch.com">hello@echo-synch.com</a></p>
  </article>
</Layout>
