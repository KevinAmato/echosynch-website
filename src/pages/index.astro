  .how-mock-pill-indigo { background: var(--echo-indigo-50); color: var(--echo-indigo-700); border-color: var(--echo-indigo-100); }
  .how-mock-pill-rose { background: #FFF1F2; color: var(--status-rose); border-color: #FECDD3; }

  .how-mock-sla { padding: 12px; }
  .how-mock-ticket {
    display: flex; justify-content: space-between; align-items: center;
