---
// Landing page (/) — the only page most visitors will ever see.
//
// Section order (locked by brand voice + competitive research):
//   1. Hero          — eyebrow + headline ≤10 words + 2-sentence lead +
//                      dual CTA + trust signal + signature animation
//   2. Honest banner — single-line transition replacing the fake logo bar
//   3. Product       — 3-column feature grid (AI triage / SLA / Dashboard)
//   4. How it works  — 3 numbered steps with HTML product mocks
//   5. Compare       — vs. Suptask / Unthread (lightweight, with one
//                      honest Echo-Synch limitation row to build trust)
//   6. Pricing       — 2 tiers (Pro / Enterprise) with monthly/yearly
//                      toggle. Trial is a banner, not a fake tier.
//   7. FAQ           — 6 questions max, accordion
//   8. CTA strip     — final "Add to Slack" CTA on indigo glow
//
// What we deliberately don't do: testimonials (no real ones yet, fake
// ones are obvious), case studies (same), videos auto-playing (slow),
// live chat widgets (visual noise, GDPR overhead), counters with
// animated numbers (taste violation per design system).

import Layout from '../layouts/Layout.astro';
import HeroAnimation from '../components/HeroAnimation.astro';

// Every "Add to Slack" / "Start free trial" CTA points directly at
// the bot's OAuth install URL. Pre-Marketplace-approval, direct-link
// installs still work — Slack just adds an "in development" banner to
// the consent screen. The Marketplace listing only affects
// discoverability inside Slack's App Directory.
//
// History: previously every CTA opened a WaitlistModal that POST'd
// emails to a Resend audience. Removed April 2026 once the bot was
// production-ready and we wanted real install signal (Slack reviews
// require ≥5 active workspaces, and a waitlist gate was preventing
// us from earning that signal organically).

const SITE = 'https://echo-synch.com';
---

<Layout
  title="Echo-Synch — Slack-native IT triage with AI labels & per-priority SLAs"
  description="Turn noisy Slack channels into a tracked IT queue. AI labels every request, SLA timers chase deadlines, full web dashboard. €12/agent/month. Built by the team behind Thread-Patrol."
  activeNav="product"
>
  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="hero" aria-label="Echo-Synch — IT triage for Slack">
    <div class="indigo-glow"></div>
    <div class="mk-container hero-inner">
      <div class="hero-copy">
        <p class="mk-eyebrow">Slack-native IT triage</p>
        <h1 class="mk-display">
          Turn noisy Slack channels into a tracked IT queue.
        </h1>
        <p class="mk-lead">
          Echo-Synch labels every IT request the moment it lands —
          category, priority, SLA timer, all automatic. Your team
          triages with one click; nothing important goes quiet.
        </p>

        <div class="hero-ctas">
          <a
            href="https://api.echo-synch.com/slack/install"
            class="mk-btn mk-btn-primary mk-btn-lg"
          >
            Add to Slack
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href="#how-it-works" class="mk-btn mk-btn-secondary mk-btn-lg">
            How it works ↓
          </a>
        </div>

        <ul class="hero-bullets">
          <li>14-day Enterprise trial when live</li>
          <li>·</li>
          <li>No credit card</li>
          <li>·</li>
          <li>One launch email — no marketing</li>
        </ul>

        <p class="hero-trust">
          Made by the team behind
          <a href="https://thread-patrol.com" target="_blank" rel="noopener noreferrer">
            <strong>Thread-Patrol</strong>
          </a>
          — a Slack-Directory-listed bot already running in production.
        </p>

        <p class="hero-status" role="status">
          <span class="hero-status-dot" aria-hidden="true"></span>
          Awaiting Slack Directory approval — drop your email and we'll
          message you the moment Echo-Synch is live.
        </p>
      </div>

      <div class="hero-anim-wrap">
        <HeroAnimation />
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. TRANSITION BANNER (honest replacement for the fake logo bar)
       ============================================================ -->
  <section class="mk-section-tight transition-band" aria-hidden="true">
    <div class="mk-container">
      <p class="transition-line">
        Built for IT teams of <strong>5–50 agents</strong> who already
        live in Slack — not a separate tool.
      </p>
    </div>
  </section>

  <!-- ============================================================
       3. PRODUCT — feature grid
       ============================================================ -->
  <section id="product" class="mk-section">
    <div class="mk-container">
      <div class="section-head">
        <p class="mk-eyebrow">What Echo-Synch does</p>
        <h2 class="mk-h2">Three things that turn Slack into a real IT queue.</h2>
        <p class="mk-lead">
          Each one works alone. Stack them and your IT team stops losing
          tickets in DMs and emoji reactions.
        </p>
      </div>

      <div class="feature-grid">
        <article class="mk-card">
          <div class="feat-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v5M12 16v5M3 12h5M16 12h5M5.5 5.5l3.5 3.5M15 15l3.5 3.5M5.5 18.5 9 15M15 9l3.5-3.5"/></svg>
          </div>
          <h3 class="feat-title">AI triage &amp; summaries</h3>
          <p class="feat-body">
            Every IT request is auto-categorised, prioritised, and
            summarised the moment it lands. The AI is constrained to
            your taxonomy — no surprise labels in your queue.
          </p>
          <ul class="feat-list">
            <li>Custom labels &amp; categories per workspace</li>
            <li>Optional <strong>BYOM</strong> — bring your own Gemini key</li>
            <li>Constrained outputs (no AI hallucinations)</li>
          </ul>
        </article>

        <article class="mk-card">
          <div class="feat-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <span class="feat-tier-pill" aria-label="Enterprise tier feature">Enterprise</span>
          <h3 class="feat-title">SLAs that chase themselves</h3>
          <p class="feat-body">
            Per-priority deadlines for first response and resolution.
            Echo-Synch DMs the assignee 30 min before breach and
            broadcasts to all admins on the breach itself.
          </p>
          <ul class="feat-list">
            <li>Per-priority windows (Low / Medium / High / Critical)</li>
            <li>Warning DMs before deadline, breach alerts after</li>
            <li>Channel-wide visibility for admins</li>
          </ul>
        </article>

        <article class="mk-card">
          <div class="feat-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          </div>
          <h3 class="feat-title">Web dashboard &amp; daily digest</h3>
          <p class="feat-body">
            See the full queue at a glance. Filter by priority, assignee,
            SLA status. A daily digest posts to a channel you choose so
            no one has to "open the dashboard" to know what's open.
          </p>
          <ul class="feat-list">
            <li>Full queue view with live SLA timers</li>
            <li>Round-robin or manual assignee picker</li>
            <li>Daily digest auto-posted to admin channel</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. HOW IT WORKS
       ============================================================ -->
  <section id="how-it-works" class="mk-section how">
    <div class="mk-container">
      <div class="section-head">
        <p class="mk-eyebrow">How it works</p>
        <h2 class="mk-h2">Install once. Triaged forever.</h2>
        <p class="mk-lead">
          No setup wizard, no integration call. Add the bot, pick a
          channel, your IT queue is live.
        </p>
      </div>

      <div class="how-steps">
        <!-- Step 1 -->
        <div class="how-step">
          <div class="how-num">1</div>
          <h3 class="how-title">Add to Slack</h3>
          <p class="how-body">
            Echo-Synch joins as a bot. Pick the channel(s) it should
            watch and the IT team that should triage. No spreadsheet,
            no role config.
          </p>
          <div class="how-mock how-mock-install" aria-hidden="true">
            <div class="how-mock-bar">
              <span class="how-mock-dot how-mock-dot-r"></span>
              <span class="how-mock-dot how-mock-dot-y"></span>
              <span class="how-mock-dot how-mock-dot-g"></span>
              <span class="how-mock-bar-label">slack.com/oauth</span>
            </div>
            <div class="how-mock-body">
              <div class="how-mock-lock">🔒</div>
              <div class="how-mock-prompt">
                <strong>Echo-Synch</strong> wants to access your workspace
              </div>
              <div class="how-mock-allow">Allow</div>
            </div>
          </div>
        </div>

        <div class="how-connector" aria-hidden="true">
          <div class="how-connector-track"></div>
        </div>

        <!-- Step 2 -->
        <div class="how-step">
          <div class="how-num">2</div>
          <h3 class="how-title">It listens. Quietly.</h3>
          <p class="how-body">
            Every request gets a label, priority, and summary. The bot
            replies in-thread with the suggested triage; your team
            confirms with one click.
          </p>
          <div class="how-mock how-mock-msg" aria-hidden="true">
            <div class="how-mock-msg-row">
              <div class="how-mock-avatar how-mock-avatar-blue">M</div>
              <div class="how-mock-msg-text">
                <strong>Maria</strong> <span class="how-mock-msg-time">9:42</span><br/>
                Printer keeps jamming…
              </div>
            </div>
            <div class="how-mock-msg-row">
              <div class="how-mock-avatar how-mock-avatar-indigo">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5C21 16.1944 16.9706 20 12 20C10.6698 20 9.40698 19.7346 8.27117 19.2612L3 21L4.60627 16.3213C3.60195 14.9458 3 13.292 3 11.5C3 6.80558 7.02944 3 12 3C16.9706 3 21 6.80558 21 11.5Z"/><path d="M9 14V10"/><path d="M12 15.5V8.5"/><path d="M15 14V10"/></svg>
              </div>
              <div class="how-mock-msg-tags">
                <span class="how-mock-pill how-mock-pill-indigo">Hardware</span>
                <span class="how-mock-pill how-mock-pill-rose">High</span>
              </div>
            </div>
          </div>
        </div>

        <div class="how-connector" aria-hidden="true">
          <div class="how-connector-track"></div>
        </div>

        <!-- Step 3 -->
        <div class="how-step">
          <div class="how-num">3</div>
          <h3 class="how-title">SLAs do the chasing</h3>
          <p class="how-body">
            Deadlines tick. Warnings DM the assignee. Breaches notify
            admins. The dashboard shows the queue, the daily digest
            keeps it visible.
            <span class="how-tier-note">Per-priority SLAs are an Enterprise feature; Pro tier gets one flat window.</span>
          </p>
          <div class="how-mock how-mock-sla" aria-hidden="true">
            <div class="how-mock-ticket">
              <span class="how-mock-ticket-title">Printer jam — 3rd floor</span>
              <span class="how-mock-pill how-mock-pill-rose">High</span>
            </div>
            <div class="how-mock-sla-row">
              <span class="how-mock-clock">⏱</span>
              <div class="how-mock-sla-bar">
                <div class="how-mock-sla-fill"></div>
              </div>
              <span class="how-mock-sla-time">2h left</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. COMPARE (descriptive, not adversarial)
       ============================================================ -->
  <section id="compare" class="mk-section compare">
    <div class="mk-container">
      <div class="section-head">
        <p class="mk-eyebrow">Where Echo-Synch fits</p>
        <h2 class="mk-h2">A balanced look at the Slack-native IT triage market.</h2>
        <p class="mk-lead">
          A few credible alternatives exist. Here's where Echo-Synch
          aligns with each — including what we don't do yet.
        </p>
      </div>

      <div class="compare-table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th></th>
              <th>Echo-Synch</th>
              <th>Suptask</th>
              <th>Unthread</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Lives entirely in Slack</td><td>✓</td><td>✓</td><td>✓</td></tr>
            <tr><td>AI triage with custom taxonomy</td><td>✓</td><td>—</td><td>✓</td></tr>
            <tr><td>Per-priority SLA windows (different deadlines for Critical vs Low)</td><td>✓</td><td>Pro tier</td><td>Pro tier</td></tr>
            <tr><td>Bring-your-own LLM (route AI through your own GCP project)</td><td>✓</td><td>—</td><td>—</td></tr>
            <tr class="compare-limitation"><td>Microsoft Teams support</td><td>—</td><td>—</td><td>✓</td></tr>
            <tr class="compare-limitation"><td>Bidirectional sync to Jira / Zendesk</td><td>—</td><td>✓</td><td>✓</td></tr>
            <tr class="compare-price"><td>Starting price (per agent / month)</td><td><strong>€12</strong></td><td>~$8</td><td>$50+</td></tr>
          </tbody>
        </table>
      </div>
      <p class="compare-fineprint">
        Comparison reflects publicly available pricing as of 2026.
        Echo-Synch is positioned for the small-to-mid IT team segment;
        for full Microsoft Teams support or bidirectional ticket sync,
        Suptask and Unthread are mature alternatives.
      </p>
    </div>
  </section>

  <!-- ============================================================
       6. PRICING — 2 tiers + monthly/yearly toggle
       ============================================================ -->
  <section id="pricing" class="mk-section pricing">
    <div class="mk-container">
      <div class="section-head">
        <p class="mk-eyebrow">Pricing</p>
        <h2 class="mk-h2">Per agent. Not per requestor.</h2>
        <p class="mk-lead">
          You pay for the IT teammates who triage. Everyone in your
          workspace can submit requests for free.
        </p>
      </div>

      <!-- Trial banner replaces the old fake "Trial tier" card. Trial
           is a time window, not a plan. Surfacing it as a banner is
           more accurate AND more visible than a third pricing card. -->
      <div class="trial-banner" role="note">
        <span class="trial-banner-icon" aria-hidden="true">🎁</span>
        Every plan starts with a <strong>14-day free Enterprise trial</strong> —
        no credit card, every feature unlocked, auto-expires.
      </div>

      <!-- Monthly / Yearly toggle. Yearly == 10×monthly (~17% off, two
           months free), aligned with the LemonSqueezy variants we
           already created (1574435/40 = Pro M/Y, 1574444/48 = Ent M/Y). -->
      <div class="pricing-toggle" role="group" aria-label="Billing period">
        <button
          type="button"
          class="pricing-toggle-btn pricing-toggle-active"
          data-billing="monthly"
          aria-pressed="true"
        >Monthly</button>
        <button
          type="button"
          class="pricing-toggle-btn"
          data-billing="yearly"
          aria-pressed="false"
        >Yearly <span class="pricing-toggle-save">save ~17%</span></button>
      </div>

      <div class="pricing-grid pricing-grid-2col" data-billing="monthly">
        <article class="mk-card pricing-card">
          <div class="price-tier">Pro</div>
          <div class="price-amount" data-monthly="12" data-yearly="10">
            €<span class="price-num">12</span>
            <span class="price-suffix"> / agent / mo</span>
          </div>
          <p class="price-billed-as price-billed-yearly">
            Billed annually as €120 / agent / year
          </p>
          <p class="price-billed-as price-billed-monthly">
            Billed monthly · cancel anytime
          </p>
          <p class="price-hint">
            For teams that need basic SLA tracking and a queue they can
            see outside Slack.
          </p>
          <ul class="price-feats">
            <li>Unlimited channels &amp; requests</li>
            <li>AI triage and summaries</li>
            <li>Flat-deadline SLA (one window for all priorities)</li>
            <li>Daily digest, web dashboard</li>
            <li>Up to 10 custom labels</li>
          </ul>
          <a
            href="https://api.echo-synch.com/slack/install"
            class="mk-btn mk-btn-secondary"
          >Start free trial</a>
        </article>

        <article class="mk-card mk-card-tinted pricing-card pricing-card-featured">
          <div class="price-tier">Enterprise</div>
          <div class="price-amount" data-monthly="22" data-yearly="18">
            €<span class="price-num">22</span>
            <span class="price-suffix"> / agent / mo</span>
          </div>
          <p class="price-billed-as price-billed-yearly">
            Billed annually as €216 / agent / year
          </p>
          <p class="price-billed-as price-billed-monthly">
            Billed monthly · cancel anytime
          </p>
          <p class="price-hint">
            For teams with real urgency tiers — when "Critical" needs a
            1-hour deadline and "Low" gets 24 hours, you need
            per-priority SLAs. That's this tier.
          </p>
          <ul class="price-feats">
            <li>Everything in Pro</li>
            <li><strong>Per-priority SLA windows</strong> (different deadlines per severity)</li>
            <li><strong>BYOM</strong> — route AI through your own Gemini key</li>
            <li>Custom taxonomy (unlimited labels)</li>
            <li>Admin broadcast on SLA breach</li>
            <li>Priority support</li>
          </ul>
          <a
            href="https://api.echo-synch.com/slack/install"
            class="mk-btn mk-btn-primary"
          >Start free trial</a>
        </article>
      </div>

      <p class="pricing-fineprint">
        50+ agents or non-standard requirements?
        <a href="mailto:support@echo-synch.com?subject=Echo-Synch%20%E2%80%94%20volume%20pricing">
          Email us
        </a> — we work with larger teams individually.
      </p>
    </div>
  </section>

  <!-- ============================================================
       7. FAQ
       ============================================================ -->
  <section id="faq" class="mk-section">
    <div class="mk-container mk-container-narrow">
      <div class="section-head">
        <p class="mk-eyebrow">FAQ</p>
        <h2 class="mk-h2">Common questions</h2>
      </div>

      <div class="faq-list">
        <details class="faq-item">
          <summary>What counts as an "agent"?</summary>
          <p>An agent is anyone who triages requests — admins or members of your IT-team roster. Everyone else in your Slack workspace can submit requests for free. A 100-person company with 3 IT staff is a 3-seat customer.</p>
        </details>

        <details class="faq-item">
          <summary>Do I need to enter a credit card to start?</summary>
          <p>No. Every install gets a 14-day Enterprise trial with no card required. Reminder DMs land at days 7, 5, 3, 2, 1 before expiry. After the trial, the bot stops responding until you subscribe — your data stays intact.</p>
        </details>

        <details class="faq-item">
          <summary>What happens to my data if I uninstall?</summary>
          <p>We hard-delete every workspace's data within 1 hour of uninstall. The 1-hour window exists so that legitimate reinstalls (e.g. accidental uninstalls) don't lose history. Full details in <a href="/privacy">privacy</a> and <a href="/dpa">DPA</a>.</p>
        </details>

        <details class="faq-item">
          <summary>Can I bring my own AI provider (BYOM)?</summary>
          <p>Yes — Enterprise tier. Plug in your own Google Gemini API key and Echo-Synch routes all triage AI calls through your account. We never see your raw IT request text. <a href="/trust-center">Trust center →</a></p>
        </details>

        <details class="faq-item">
          <summary>Does it work with Microsoft Teams?</summary>
          <p>Not yet. Echo-Synch is Slack-only by design — that's why it's deeply integrated. Teams support is on the roadmap but won't ship before paying-customer demand justifies the rebuild.</p>
        </details>

        <details class="faq-item">
          <summary>What's "Made in Italy" about?</summary>
          <p>Echo-Synch is built solo from Rome. Hosted on AWS Ireland (eu-west-1) with EU data residency by default. Run by humans you can email.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- ============================================================
       8. FINAL CTA STRIP
       ============================================================ -->
  <section class="cta-strip">
    <div class="indigo-glow"></div>
    <div class="mk-container">
      <h2 class="mk-h2">Ready to stop losing tickets in DMs?</h2>
      <p class="mk-lead">
        Drop your email — we'll message you the moment Echo-Synch is
        live on Slack Directory. One email, no marketing.
      </p>
      <a
        href="https://api.echo-synch.com/slack/install"
        class="mk-btn mk-btn-primary mk-btn-lg"
      >
        Add to Slack
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- ============================================================
       Schema.org FAQPage — duplicates the visible FAQ for search
       engines. Same Q&A array as above so they can never drift.
       ============================================================ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'What counts as an "agent"?',
        acceptedAnswer: { '@type': 'Answer', text: 'An agent is anyone who triages requests — admins or members of your IT-team roster. Everyone else in your Slack workspace can submit requests for free.' } },
      { '@type': 'Question', name: 'Do I need to enter a credit card to start?',
        acceptedAnswer: { '@type': 'Answer', text: 'No. Every install gets a 14-day Enterprise trial with no card required.' } },
      { '@type': 'Question', name: 'What happens to my data if I uninstall?',
        acceptedAnswer: { '@type': 'Answer', text: 'We hard-delete every workspace\'s data within 1 hour of uninstall.' } },
      { '@type': 'Question', name: 'Can I bring my own AI provider (BYOM)?',
        acceptedAnswer: { '@type': 'Answer', text: 'Yes — Enterprise tier. Plug in your own Google Gemini API key and Echo-Synch routes all triage AI calls through your account.' } },
      { '@type': 'Question', name: 'Does it work with Microsoft Teams?',
        acceptedAnswer: { '@type': 'Answer', text: 'Not yet. Echo-Synch is Slack-only by design — Teams support is on the roadmap.' } },
    ],
  })} />
</Layout>

<style>
  /* ---------- Hero ---------- */
  .hero {
    position: relative;
    padding: 120px 0 96px;
    overflow: hidden;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: 56px;
    align-items: center;
  }
  .hero-copy { max-width: 560px; }
  .hero-copy .mk-display { margin-bottom: 20px; }
  .hero-copy .mk-lead { margin-bottom: 28px; }
  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .hero-bullets {
    list-style: none; padding: 0; margin: 20px 0 0;
    display: flex; flex-wrap: wrap; gap: 8px;
    font-size: 13px; color: var(--fg-3);
  }
  .hero-trust {
    margin: 16px 0 0; font-size: 13px;
    color: var(--fg-3); line-height: 1.5;
  }
  .hero-trust a { color: var(--fg-2); text-decoration: none; }
  .hero-trust a:hover { color: var(--echo-indigo); }
  .hero-trust strong { color: var(--fg-1); font-weight: 700; }

  /* Status pill — small, secondary-weight, sits below trust signal so
   * it doesn't fragment the H1 → CTA visual rhythm. Color block reads
   * as "informational" rather than "alarm". */
  .hero-status {
    margin: 14px 0 0;
    padding: 8px 14px;
    background: color-mix(in oklab, var(--echo-indigo-50), white 30%);
