    background: linear-gradient(90deg, var(--status-amber), var(--status-rose));
  }
  .how-mock-sla-time { font-family: var(--font-mono); font-size: 10px; }

  /* ---------- Compare table ---------- */
  .compare-table-wrap {
    border: 1px solid var(--border-subtle); border-radius: 16px;
    background: #fff; overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .compare-table {
    width: 100%; border-collapse: collapse;
    font-size: 14px;
  }
  .compare-table th, .compare-table td {
    padding: 14px 18px; text-align: left;
    border-bottom: 1px solid var(--border-subtle);
  }
  .compare-table th {
    font-size: 12px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
    color: var(--fg-3); background: var(--slate-50);
  }
  .compare-table th:nth-child(2) { color: var(--echo-indigo); }
  .compare-table tbody tr:last-child td { border-bottom: 0; }
  .compare-table td:first-child { color: var(--fg-2); font-weight: 500; }
  .compare-table td:nth-child(2) {
    font-weight: 600;
    background: color-mix(in oklab, var(--echo-indigo-50), white 60%);
  }
  /* Limitation rows: subtly de-emphasised so visitors see them as
   * honest disclosure, not "we lose at this." */
  .compare-table tr.compare-limitation td:first-child {
    color: var(--fg-3);
  }
  .compare-table tr.compare-limitation td:first-child::before {
    content: '⚠ '; color: var(--status-amber); font-size: 12px;
  }
  /* Price row: slight visual separation. */
  .compare-table tr.compare-price td {
    background: var(--slate-50);
    border-top: 2px solid var(--border-subtle);
  }
  .compare-table tr.compare-price td:nth-child(2) {
    background: var(--echo-indigo-50);
  }
  .compare-fineprint {
    text-align: center; font-size: 13px;
    color: var(--fg-3); margin: 24px auto 0;
    max-width: 600px; line-height: 1.6;
  }

  /* ---------- Pricing ---------- */

  /* Trial banner — replaces the fake "Trial tier" card. Sits between
   * section header and pricing grid as a one-line callout. */
  .trial-banner {
    max-width: 720px; margin: 0 auto 32px;
    padding: 14px 20px;
    background: var(--echo-indigo-50);
    border: 1px solid var(--echo-indigo-100);
    border-radius: 12px;
    text-align: center;
    font-size: 14.5px;
    color: var(--echo-indigo-700);
    line-height: 1.5;
  }
  .trial-banner strong { font-weight: 700; }
  .trial-banner-icon {
    margin-right: 6px;
  }

  /* Monthly / Yearly toggle — segmented control above pricing cards. */
  .pricing-toggle {
    display: inline-flex;
    margin: 0 auto 32px;
    padding: 4px;
    background: var(--slate-100);
    border-radius: 12px;
    gap: 0;
    width: fit-content;
    text-align: center;
  }
  .pricing-toggle-btn {
    padding: 8px 18px; border-radius: 8px;
    font-size: 14px; font-weight: 600;
    color: var(--fg-3);
    background: transparent;
    border: 0; cursor: pointer;
    transition: all 180ms;
    font-family: inherit;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .pricing-toggle-btn:hover { color: var(--fg-1); }
  .pricing-toggle-btn.pricing-toggle-active {
    background: #fff;
    color: var(--fg-1);
    box-shadow: var(--shadow-sm);
  }
  .pricing-toggle-save {
    font-size: 11px; font-weight: 700;
    padding: 2px 8px; border-radius: 9999px;
    background: var(--echo-indigo-50);
    color: var(--echo-indigo-700);
    border: 1px solid var(--echo-indigo-100);
    text-transform: uppercase; letter-spacing: 0.04em;
  }

  /* Center the toggle. Wrap div is hand-rolled here to keep a single
   * inline-block centred without flexbox-of-flexbox. */
  .section-head + .trial-banner { margin-top: -24px; }
  .pricing .pricing-toggle {
    display: flex; margin-left: auto; margin-right: auto;
  }

  .pricing-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 24px; align-items: stretch;
  }
  .pricing-grid-2col {
    grid-template-columns: repeat(2, minmax(0, 360px));
    justify-content: center;
  }
  .pricing-card {
    display: flex; flex-direction: column;
    padding: 32px;
    position: relative;
  }
  .pricing-card-featured {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }
  .price-tier {
    font-family: var(--font-mono); font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--echo-indigo);
    margin-bottom: 8px;
  }
  .price-amount {
    font-size: 40px; font-weight: 800; color: var(--fg-1);
    letter-spacing: -0.02em; line-height: 1; margin-bottom: 4px;
  }
  .price-suffix { font-size: 14px; font-weight: 500; color: var(--fg-3); letter-spacing: 0; }
  .price-billed-as {
    font-size: 12px; color: var(--fg-4);
    margin: 0 0 16px;
  }
  /* Show the right "billed as" line for the active billing mode. JS
   * toggles the [data-billing] attribute on the grid. */
  .price-billed-yearly { display: none; }
  .pricing-grid[data-billing="yearly"] .price-billed-monthly { display: none; }
  .pricing-grid[data-billing="yearly"] .price-billed-yearly { display: block; }

  .price-hint {
    font-size: 13.5px; color: var(--fg-3);
    margin: 0 0 24px;
    min-height: 60px;
  }
  .price-feats {
    list-style: none; padding: 0; margin: 0 0 24px;
    display: flex; flex-direction: column; gap: 10px;
    font-size: 14px; color: var(--fg-2); flex: 1;
  }
  .price-feats li::before { content: '✓'; color: var(--echo-indigo); margin-right: 8px; font-weight: 700; }
  .pricing-fineprint {
    text-align: center; font-size: 13px; color: var(--fg-3);
    margin: 32px 0 0;
  }
  @media (max-width: 720px) {
    .pricing-grid-2col { grid-template-columns: 1fr; }
    .pricing-card-featured { transform: none; }
  }

  /* FAQ styles live in global.css (used by /support too). */

  /* ---------- CTA strip ---------- */
  .cta-strip {
    position: relative;
    text-align: center;
    padding: 96px 0;
    overflow: hidden;
    border-top: 1px solid var(--border-subtle);
  }
  .cta-strip .mk-h2 { max-width: 640px; margin: 0 auto 16px; }
  .cta-strip .mk-lead { margin: 0 auto 32px; max-width: 560px; }
</style>

<script>
  // Pricing monthly/yearly toggle. The visible numbers are read from
  // data-monthly / data-yearly on each .price-amount; toggling the
  // grid's data-billing attribute shows the right "billed as" line via
  // CSS. JS handles only the number swap + button active state.
  document.querySelectorAll<HTMLElement>('.pricing-toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const billing = btn.dataset.billing as 'monthly' | 'yearly';
      const grid = btn.closest('section')?.querySelector<HTMLElement>('.pricing-grid');
      if (!grid) return;

      // Update grid attribute (drives CSS for billing-as line)
      grid.dataset.billing = billing;

      // Update toggle button active state + aria
      btn.parentElement?.querySelectorAll('.pricing-toggle-btn').forEach(b => {
        b.classList.remove('pricing-toggle-active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('pricing-toggle-active');
      btn.setAttribute('aria-pressed', 'true');

      // Swap the visible number on each card
      grid.querySelectorAll<HTMLElement>('.price-amount').forEach(amt => {
        const numEl = amt.querySelector<HTMLElement>('.price-num');
        if (!numEl) return;
        numEl.textContent = billing === 'yearly'
          ? (amt.dataset.yearly ?? '')
          : (amt.dataset.monthly ?? '');
      });
    });
  });
</script>
