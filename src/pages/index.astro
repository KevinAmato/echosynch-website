---
// Landing page (/) — the only page most visitors will ever see.
//
// Section order (locked by brand voice + competitive research):
//   1. Hero          — eyebrow + headline ≤10 words + 25-word lead + dual CTA
//                      + the signature animation (Slack → triage → dashboard)
//   2. Logo bar      — placeholder until first design partners are public
//   3. Product       — 3-column feature grid (AI triage / SLA / BYOM)
//   4. How it works  — 3 numbered steps, with screenshots from the dashboard
//   5. Compare       — vs. Suptask / Unthread / DIY-spreadsheet (lightweight,
//                      not the dedicated comparison pages — those come later)
//   6. Pricing       — 3 tiers (Free / Pro / Enterprise) with monthly toggle
//   7. FAQ           — 6 questions max, accordion
//   8. CTA strip     — final "Add to Slack" + indigo glow
//
// What we deliberately don't do: testimonials (no real ones yet, fake ones
// are obvious), case studies (same), videos auto-playing (slow), live chat
// widgets (visual noise, GDPR overhead), counters with animated numbers
// (taste violation per design system).

import Layout from '../layouts/Layout.astro';
import HeroAnimation from '../components/HeroAnimation.astro';

// Pre-launch state: every "Add to Slack" CTA opens the WaitlistModal
// (data-waitlist="<source>") rather than going to api.echo-synch.com/
// slack/install. Slack Directory review takes 2-3 weeks; until then
// public installs would fail. Each CTA has a unique source tag so we
// can later see in the notification emails which surface converted.
//
// When Slack approves, search-replace the `data-waitlist` attributes
// with `href="https://api.echo-synch.com/slack/install"` and remove the
// "Coming soon" pills.
---

<Layout
  title="Echo-Synch — Slack-native IT triage with AI summaries and SLAs"
  description="Turn noisy Slack channels into tracked, accountable IT work — without the process tax. Per-priority SLAs, AI summaries, BYOM. €12/agent/month."
  activeNav="product"
>
  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="hero">
    <div class="indigo-glow"></div>
    <div class="mk-container hero-inner">
      <div class="hero-copy">
        <p class="mk-eyebrow">Slack-native IT triage</p>
        <h1 class="mk-display">
          Turn noisy Slack channels into tracked IT work.
        </h1>
        <p class="mk-lead">
          Echo-Synch watches your IT-help channels, AI-triages every request,
          and puts a clock on it — so nothing important goes quiet.
        </p>
        <div class="hero-cta-row">
          <span class="mk-pill mk-pill-coming-soon">
            Awaiting Slack approval — drop your email
          </span>
        </div>
        <div class="hero-ctas">
          <a
            href="#waitlist"
            class="mk-btn mk-btn-primary mk-btn-lg"
            data-waitlist="hero"
          >
            Notify me at launch
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href="#product" class="mk-btn mk-btn-secondary mk-btn-lg">
            See how it works
          </a>
        </div>
        <ul class="hero-bullets">
          <li>14-day Enterprise trial when live</li>
          <li>·</li>
          <li>No credit card</li>
          <li>·</li>
          <li>One launch email, no marketing</li>
        </ul>
      </div>

      <div class="hero-anim-wrap">
        <HeroAnimation />
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. LOGO BAR (placeholder until design partners go public)
       ============================================================ -->
  <section class="mk-section-tight logobar">
    <div class="mk-container">
      <p class="logobar-label">Built for IT teams who live in Slack</p>
      <div class="logobar-strip" aria-hidden="true">
        <span>RevOps</span>
        <span>Five9</span>
        <span>SecOps</span>
        <span>HelpDesk</span>
        <span>Platform Eng</span>
      </div>
    </div>
  </section>

  <!-- ============================================================
       3. PRODUCT — feature grid
       ============================================================ -->
  <section id="product" class="mk-section">
    <div class="mk-container">
      <div class="section-head">
        <p class="mk-eyebrow">What it does</p>
        <h2 class="mk-h2">Three primitives, one tracked queue.</h2>
        <p class="mk-lead">
          Each feature works alone. Stack them and your IT team stops
          losing tickets in DMs and emoji reactions.
        </p>
      </div>

      <div class="feature-grid">
        <article class="mk-card">
          <div class="feat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v5M12 16v5M3 12h5M16 12h5M5.5 5.5l3.5 3.5M15 15l3.5 3.5M5.5 18.5 9 15M15 9l3.5-3.5"/></svg>
          </div>
          <h3 class="feat-title">AI triage &amp; summaries</h3>
          <p class="feat-body">
            Every IT request is auto-categorised, prioritised, and summarised
            on the way in. Constrain the AI to your own taxonomy — no
            free-form labels at 3am.
          </p>
          <ul class="feat-list">
            <li>Custom labels &amp; categories per workspace</li>
            <li>Optional <strong>BYOM</strong> — bring your own Gemini key</li>
            <li>Constrained outputs (no AI hallucinations in your queue)</li>
          </ul>
        </article>

        <article class="mk-card mk-card-tinted">
          <div class="feat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <span class="mk-pill" style="position: absolute; top: -10px; right: 16px;">Enterprise</span>
          <h3 class="feat-title">SLAs that chase themselves</h3>
          <p class="feat-body">
            Per-priority deadlines for first response and resolution.
            Echo-Synch DMs the assignee 30 min before breach and broadcasts
            on the breach itself — across every triage member.
          </p>
          <ul class="feat-list">
            <li>Per-priority SLA windows (Low / Medium / High / Critical)</li>
            <li>Warning DMs before deadline, breach alerts after</li>
            <li>Channel-wide visibility for admins</li>
          </ul>
        </article>

        <article class="mk-card">
          <div class="feat-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          </div>
          <h3 class="feat-title">Web dashboard, daily digest</h3>
          <p class="feat-body">
            See the full queue at a glance. Filter by priority, assignee,
            SLA status. Daily digest posts to a channel of your choosing —
            no one has to "open the dashboard" to know what's open.
          </p>
          <ul class="feat-list">
            <li>Full queue view with SLA timers</li>
            <li>Round-robin or manual assignee picker</li>
            <li>Daily digest auto-posted to admin channel</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. HOW IT WORKS
       ============================================================ -->
  <section id="how-it-works" class="mk-section how">
    <div class="mk-container">
      <div class="section-head">
        <p class="mk-eyebrow">How it works</p>
        <h2 class="mk-h2">Install once. Triaged forever.</h2>
        <p class="mk-lead">
          Three minutes from "Add to Slack" to "first triaged ticket".
          No setup wizard, no integration call.
        </p>
      </div>

      <div class="how-steps">
        <div class="how-step">
          <div class="how-num">1</div>
          <h3 class="how-title">Add to Slack</h3>
          <p class="how-body">
            Echo-Synch joins as a bot. Pick the channel(s) it should watch
            and the IT team that should triage. No spreadsheet, no role config.
          </p>
        </div>
        <div class="how-connector" aria-hidden="true">
          <div class="how-connector-track"></div>
        </div>
        <div class="how-step">
          <div class="how-num">2</div>
          <h3 class="how-title">It listens. Quietly.</h3>
          <p class="how-body">
            Every request gets summarised, categorised, and prioritised.
            Threads stay in Slack — no separate tool, no context switch.
          </p>
        </div>
        <div class="how-connector" aria-hidden="true">
          <div class="how-connector-track"></div>
        </div>
        <div class="how-step">
          <div class="how-num">3</div>
          <h3 class="how-title">SLAs do the chasing</h3>
          <p class="how-body">
            Deadlines tick. Warnings DM the assignee. Breaches notify admins.
            The dashboard shows the queue, the daily digest keeps it visible.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. COMPARE (lightweight — full pages later)
       ============================================================ -->
  <section id="compare" class="mk-section compare">
    <div class="mk-container">
      <div class="section-head">
        <p class="mk-eyebrow">Where Echo-Synch fits</p>
        <h2 class="mk-h2">Suptask at Suptask prices. Unthread features at half the cost.</h2>
        <p class="mk-lead">
          The Slack-native IT triage market splits into two camps: cheap
          ticketing wrappers and AI-heavy enterprise tools. Echo-Synch is
          the middle: enterprise-grade SLAs at a Pro-tier price.
        </p>
      </div>

      <div class="compare-table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th></th>
              <th>Echo-Synch <span class="mk-pill" style="margin-left:8px;">Recommended</span></th>
              <th>Suptask</th>
              <th>Unthread</th>
              <th>DIY (spreadsheet)</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Lives entirely in Slack</td><td>✓</td><td>✓</td><td>✓</td><td>—</td></tr>
            <tr><td>AI triage with custom taxonomy</td><td>✓</td><td>—</td><td>✓</td><td>—</td></tr>
            <tr><td>Per-priority SLA windows</td><td>✓</td><td>Pro tier</td><td>Pro tier</td><td>—</td></tr>
            <tr><td>Bring-your-own LLM (BYOM)</td><td>✓</td><td>—</td><td>—</td><td>—</td></tr>
            <tr><td>Starting price (per agent/mo)</td><td><strong>€12</strong></td><td>~$8</td><td>$50+</td><td>Your time</td></tr>
            <tr><td>Slack Directory listed</td><td>✓</td><td>✓</td><td>✓</td><td>—</td></tr>
          </tbody>
        </table>
      </div>
      <p class="compare-fineprint">
        Pricing as of {new Date().getFullYear()}. We refresh this when
        anyone adjusts. <a href="/blog">Read the deep-dive comparison →</a>
      </p>
    </div>
  </section>

  <!-- ============================================================
       6. PRICING
       ============================================================ -->
  <section id="pricing" class="mk-section pricing">
    <div class="mk-container">
      <div class="section-head">
        <p class="mk-eyebrow">Pricing</p>
        <h2 class="mk-h2">Per agent. Not per requestor.</h2>
        <p class="mk-lead">
          You pay for the IT teammates who triage. Everyone in your
          workspace can submit requests for free.
        </p>
      </div>

      <div class="pricing-grid">
        <article class="mk-card pricing-card">
          <div class="price-tier">Trial</div>
          <div class="price-amount">€0<span class="price-suffix"> / 14 days</span></div>
          <p class="price-hint">Full Enterprise on every install. No card.</p>
          <ul class="price-feats">
            <li>Every Enterprise feature, unlimited use</li>
            <li>14 days, then auto-expires</li>
            <li>Reminder DMs at days 7, 3, 1</li>
          </ul>
          <a
            href="#waitlist"
            class="mk-btn mk-btn-secondary"
            data-waitlist="pricing-trial"
          >Notify me at launch</a>
        </article>

        <article class="mk-card pricing-card">
          <div class="price-tier">Pro</div>
          <div class="price-amount">€12<span class="price-suffix"> / agent / mo</span></div>
          <p class="price-hint">For teams that need basic SLA tracking.</p>
          <ul class="price-feats">
            <li>Unlimited channels &amp; requests</li>
            <li>AI triage and summaries</li>
            <li>Basic SLA (flat deadlines)</li>
            <li>Daily digest, web dashboard</li>
            <li>Up to 10 custom labels</li>
          </ul>
          <a
            href="#waitlist"
            class="mk-btn mk-btn-secondary"
            data-waitlist="pricing-pro"
          >Notify me at launch</a>
        </article>

        <article class="mk-card mk-card-tinted pricing-card pricing-card-featured">
          <span class="mk-pill" style="position: absolute; top: -12px; right: 20px;">Most popular</span>
          <div class="price-tier">Enterprise</div>
          <div class="price-amount">€22<span class="price-suffix"> / agent / mo</span></div>
          <p class="price-hint">For teams that need the full triage system.</p>
          <ul class="price-feats">
            <li>Everything in Pro</li>
            <li><strong>Per-priority SLA windows</strong></li>
            <li><strong>BYOM</strong> — bring your own Gemini API key</li>
            <li>Custom taxonomy (unlimited labels)</li>
            <li>Admin broadcast on SLA breach</li>
            <li>Priority support</li>
          </ul>
          <a
            href="#waitlist"
            class="mk-btn mk-btn-primary"
            data-waitlist="pricing-enterprise"
          >Notify me at launch</a>
        </article>
      </div>

      <p class="pricing-fineprint">
        Annual plans save ~17% (paying 10 months for 12). Switch anytime
        from <a href="https://app.echo-synch.com">the dashboard</a>.
      </p>
    </div>
  </section>

  <!-- ============================================================
       7. FAQ
       ============================================================ -->
  <section id="faq" class="mk-section">
    <div class="mk-container mk-container-narrow">
      <div class="section-head">
        <p class="mk-eyebrow">FAQ</p>
        <h2 class="mk-h2">Common questions</h2>
      </div>

      <div class="faq-list">
        <details class="faq-item">
          <summary>What counts as an "agent"?</summary>
          <p>An agent is anyone who triages requests — admins or members of your IT-team roster. Everyone else in your Slack workspace can submit requests for free. A 100-person company with 3 IT staff is a 3-seat customer.</p>
        </details>

        <details class="faq-item">
          <summary>Do I need to enter a credit card to start?</summary>
          <p>No. Every install gets a 14-day Enterprise trial with no card required. Reminder DMs land at days 7, 5, 3, 2, 1 before expiry. After the trial, the bot stops responding until you subscribe — your data stays intact.</p>
        </details>

        <details class="faq-item">
          <summary>What happens to my data if I uninstall?</summary>
          <p>We hard-delete every workspace's data within 1 hour of uninstall. The 1-hour window exists so that legitimate reinstalls (e.g. accidental uninstalls) don't lose history. Full details in <a href="/privacy">privacy</a> and <a href="/dpa">DPA</a>.</p>
        </details>

        <details class="faq-item">
          <summary>Can I bring my own AI provider (BYOM)?</summary>
          <p>Yes — Enterprise tier. Plug in your own Google Gemini API key and Echo-Synch routes all triage AI calls through your account. We never see your raw IT request text. <a href="/trust-center">Trust center →</a></p>
        </details>

        <details class="faq-item">
          <summary>Does it work with Microsoft Teams?</summary>
          <p>Not yet. Echo-Synch is Slack-only by design — that's why it's deeply integrated. Teams support is on the roadmap but won't ship before paying customer demand justifies the rebuild.</p>
        </details>

        <details class="faq-item">
          <summary>What's "Made in Italy" about?</summary>
          <p>Echo-Synch is built solo from Rome. Hosted on AWS Ireland (eu-west-1) with EU data residency by default. Run by humans you can email.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- ============================================================
       8. FINAL CTA STRIP
       ============================================================ -->
  <section class="cta-strip">
    <div class="indigo-glow"></div>
    <div class="mk-container">
      <span class="mk-pill mk-pill-coming-soon" style="margin-bottom: 16px;">
        Coming soon — pending Slack approval
      </span>
      <h2 class="mk-h2">Ready to stop losing tickets in DMs?</h2>
      <p class="mk-lead">Drop your email and we'll message you the moment Echo-Synch is live.</p>
      <a
        href="#waitlist"
        class="mk-btn mk-btn-primary mk-btn-lg"
        data-waitlist="cta-strip"
      >
        Notify me at launch
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</Layout>

<style>
  /* ---------- Hero ---------- */
  .hero {
    position: relative;
    padding: 120px 0 96px;
    overflow: hidden;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: 56px;
    align-items: center;
  }
  .hero-copy { max-width: 560px; }
  .hero-copy .mk-display { margin-bottom: 20px; }
  .hero-copy .mk-lead { margin-bottom: 24px; }
  .hero-cta-row { margin-bottom: 16px; }
  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .hero-bullets {
    list-style: none; padding: 0; margin: 24px 0 0;
    display: flex; flex-wrap: wrap; gap: 8px;
    font-size: 13px; color: var(--fg-3);
  }
  .hero-anim-wrap { min-width: 0; }

  @media (max-width: 980px) {
    .hero { padding: 80px 0 64px; }
    .hero-inner { grid-template-columns: 1fr; gap: 48px; }
  }

  /* ---------- Logobar ---------- */
  .logobar { background: var(--slate-50); border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle); }
  .logobar-label {
    text-align: center;
    font-size: 12px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--fg-4); margin: 0 0 24px;
  }
  .logobar-strip {
    display: flex; justify-content: center; flex-wrap: wrap;
    gap: 48px; font-size: 16px; font-weight: 700; color: var(--fg-3);
    letter-spacing: -0.01em;
    opacity: 0.7;
  }

  /* ---------- Section head (used in product, how, compare, pricing, faq) ---------- */
  .section-head { text-align: center; max-width: 720px; margin: 0 auto 56px; }
  .section-head .mk-h2 { margin-bottom: 16px; }

  /* ---------- Product feature grid ---------- */
  .feature-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .feature-grid .mk-card { position: relative; padding: 28px; }
  .feat-icon {
    width: 44px; height: 44px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    background: var(--echo-indigo-50); color: var(--echo-indigo);
    margin-bottom: 16px;
  }
  .feat-title { font-size: 18px; font-weight: 700; color: var(--fg-1); margin: 0 0 8px; letter-spacing: -0.01em; }
  .feat-body { font-size: 14.5px; color: var(--fg-2); line-height: 1.6; margin: 0 0 16px; }
  .feat-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; font-size: 13.5px; color: var(--fg-2); }
  .feat-list li::before { content: '✓'; color: var(--echo-indigo); margin-right: 8px; font-weight: 700; }
  @media (max-width: 980px) { .feature-grid { grid-template-columns: 1fr; } }

  /* ---------- How it works ---------- */
  .how { background: var(--slate-50); }
  .how-steps {
    display: grid; grid-template-columns: 1fr 60px 1fr 60px 1fr;
    gap: 0; align-items: stretch;
  }
  .how-step {
    background: #fff; border: 1px solid var(--border-subtle);
    border-radius: 16px; padding: 28px;
    box-shadow: var(--shadow-sm);
    transition: transform 200ms var(--ease-out);
  }
  .how-step:hover { transform: translateY(-2px); }
  .how-num {
    width: 36px; height: 36px; border-radius: 10px;
    background: var(--echo-indigo); color: #fff;
    font-size: 16px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 16px;
  }
  .how-title { font-size: 17px; font-weight: 700; color: var(--fg-1); margin: 0 0 8px; }
  .how-body { font-size: 14.5px; color: var(--fg-2); line-height: 1.6; margin: 0; }
  .how-connector { display: flex; align-items: center; justify-content: center; }
  .how-connector-track {
    width: 100%; height: 2px;
    background: linear-gradient(90deg,
      var(--border-subtle),
      var(--echo-indigo) 50%,
      var(--border-subtle));
    border-radius: 1px;
  }
  @media (max-width: 980px) {
    .how-steps { grid-template-columns: 1fr; gap: 16px; }
    .how-connector { display: none; }
  }

  /* ---------- Compare table ---------- */
  .compare-table-wrap {
    border: 1px solid var(--border-subtle); border-radius: 16px;
    background: #fff; overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .compare-table {
    width: 100%; border-collapse: collapse;
    font-size: 14px;
  }
  .compare-table th, .compare-table td {
    padding: 14px 18px; text-align: left;
    border-bottom: 1px solid var(--border-subtle);
  }
  .compare-table th {
    font-size: 12px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
    color: var(--fg-3); background: var(--slate-50);
  }
  .compare-table th:nth-child(2) { color: var(--echo-indigo); }
  .compare-table tbody tr:last-child td { border-bottom: 0; }
  .compare-table td:first-child { color: var(--fg-2); font-weight: 500; }
  .compare-table td:nth-child(2) {
    font-weight: 600;
    background: color-mix(in oklab, var(--echo-indigo-50), white 60%);
  }
  .compare-fineprint { text-align: center; font-size: 13px; color: var(--fg-3); margin: 24px 0 0; }

  /* ---------- Pricing ---------- */
  .pricing-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 24px; align-items: stretch;
  }
  .pricing-card {
    display: flex; flex-direction: column;
    padding: 32px;
    position: relative;
  }
  .pricing-card-featured {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }
  .price-tier {
    font-family: var(--font-mono); font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--echo-indigo);
    margin-bottom: 8px;
  }
  .price-amount {
    font-size: 40px; font-weight: 800; color: var(--fg-1);
    letter-spacing: -0.02em; line-height: 1; margin-bottom: 8px;
  }
  .price-suffix { font-size: 14px; font-weight: 500; color: var(--fg-3); letter-spacing: 0; }
  .price-hint { font-size: 13.5px; color: var(--fg-3); margin: 0 0 24px; min-height: 36px; }
  .price-feats {
    list-style: none; padding: 0; margin: 0 0 24px;
    display: flex; flex-direction: column; gap: 10px;
    font-size: 14px; color: var(--fg-2); flex: 1;
