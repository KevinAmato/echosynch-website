---
// Blog index page. Lists every Astro-managed post from the `blog`
// collection, newest first, with category filter chips. Empty state
// when the collection is empty (which it will be for the first ~week
// after the pipeline goes live).
//
// No legacy posts to merge — Echo-Synch's blog is greenfield. If we
// ever migrate older HTML posts in, the merge pattern from
// thread-patrol-pages/src/pages/blog.astro is the canonical reference.

import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const astroPosts = await getCollection('blog');

const THIRTY_DAYS_MS = 30 * 24 * 60 * 60 * 1000;
const now = Date.now();

const posts = astroPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .map((p) => ({
    slug: p.id,
    title: p.data.title,
    description: p.data.description,
    category: p.data.category,
    pubDate: p.data.pubDate,
    pubDateIso: p.data.pubDate.toISOString().split('T')[0]!,
    pubDateLabel: new Date(p.data.pubDate).toLocaleDateString('en-US', {
      year: 'numeric', month: 'short', day: 'numeric',
    }),
    isNew: now - new Date(p.data.pubDate).getTime() < THIRTY_DAYS_MS,
    url: `/blog/${p.id}`,
    tags: p.data.tags,
  }));

const categories: { id: 'all' | string; label: string }[] = [
  { id: 'all',           label: 'All' },
  { id: 'ai-triage',     label: 'AI Triage' },
  { id: 'sla',           label: 'SLA' },
  { id: 'automation',    label: 'Automation' },
  { id: 'metrics',       label: 'Metrics' },
  { id: 'comparison',    label: 'Comparison' },
  { id: 'integrations',  label: 'Integrations' },
  { id: 'best-practices',label: 'Best Practices' },
  { id: 'guides',        label: 'Guides' },
];

const CATEGORY_LABELS: Record<string, string> = Object.fromEntries(
  categories.filter(c => c.id !== 'all').map(c => [c.id, c.label]),
);
---

<Layout
  title="Echo-Synch Blog — IT triage, SLAs, and Slack-native helpdesk"
  description="Practical posts for IT and helpdesk leads running internal support in Slack — AI triage, SLA tactics, automation patterns, and helpdesk metrics that matter."
  bodyClass="blog-index-body"
>
  <section class="blog-index">
    <header class="blog-hero">
      <p class="blog-eyebrow">Echo-Synch Blog</p>
      <h1 class="blog-title">IT triage, SLAs, and Slack-native helpdesk patterns</h1>
      <p class="blog-subtitle">
        Practical posts for IT managers, helpdesk leads, and internal-tools admins
        running support inside Slack. No fluff, no &ldquo;in today&rsquo;s fast-paced world&rdquo;.
      </p>
    </header>

    {posts.length > 0 && (
      <nav class="blog-filters" aria-label="Filter by category">
        {categories.map((cat) => (
          <button
            class="blog-filter"
            data-filter={cat.id}
            aria-pressed={cat.id === 'all' ? 'true' : 'false'}
          >
            {cat.label}
          </button>
        ))}
      </nav>
    )}

    {posts.length === 0 ? (
      <div class="blog-empty">
        <h2>No posts yet — the first one ships within a week.</h2>
        <p>
          We publish one practical post every Wednesday morning, generated
          from a curated keyword queue and reviewed for quality before going
          live. Topics cover IT-helpdesk SLAs, AI triage tactics, automation
          patterns, and head-to-head comparisons of tools in this space.
        </p>
        <p>
          Want a specific topic covered? Email
          <a href="mailto:support@echo-synch.com">support@echo-synch.com</a>
          and we&rsquo;ll add it to the queue.
        </p>
      </div>
    ) : (
      <ul class="blog-grid" role="list">
        {posts.map((post) => (
          <li class="blog-card" data-category={post.category}>
            <a href={post.url} class="blog-card-link">
              <div class="blog-card-meta">
                <span class="blog-card-category">{CATEGORY_LABELS[post.category] ?? post.category}</span>
                {post.isNew && <span class="blog-card-new">New</span>}
              </div>
              <h2 class="blog-card-title">{post.title}</h2>
              <p class="blog-card-desc">{post.description}</p>
              <div class="blog-card-footer">
                <time datetime={post.pubDateIso}>{post.pubDateLabel}</time>
                <span class="blog-card-arrow" aria-hidden="true">→</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Layout>

<script is:inline>
  // Client-side category filter. Pure DOM — no framework. Rebuilds
  // visibility on every chip click; works even with JS disabled
  // (filters just don't function — all posts show, which is fine).
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = Array.from(document.querySelectorAll('.blog-filter'));
    const cards = Array.from(document.querySelectorAll('.blog-card'));
    if (!buttons.length || !cards.length) return;

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');
        buttons.forEach((b) => b.setAttribute('aria-pressed', b === btn ? 'true' : 'false'));
        cards.forEach((card) => {
          if (filter === 'all') {
            card.style.display = '';
          } else {
            card.style.display = card.getAttribute('data-category') === filter ? '' : 'none';
          }
        });
      });
    });
  });
</script>

<style is:global>
  body.blog-index-body main { background: #f8fafc; }

  .blog-index {
    max-width: 1080px;
    margin: 0 auto;
    padding: 56px 24px 80px;
  }

  .blog-hero { text-align: center; margin-bottom: 40px; }
  .blog-eyebrow {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 13px;
    font-weight: 600;
    color: #4F46E5;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 12px;
  }
  .blog-title {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 40px;
    line-height: 1.15;
    font-weight: 700;
    color: #0f172a;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }
  @media (max-width: 640px) { .blog-title { font-size: 30px; } }
  .blog-subtitle {
    font-size: 17px;
    line-height: 1.6;
    color: #475569;
    max-width: 640px;
    margin: 0 auto;
  }

  .blog-filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-bottom: 40px;
  }
  .blog-filter {
    background: white;
    color: #475569;
    border: 1px solid #e2e8f0;
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
  }
  .blog-filter:hover { border-color: #cbd5e1; color: #1e293b; }
  .blog-filter[aria-pressed="true"] {
    background: #4F46E5;
    color: white;
    border-color: #4F46E5;
  }

  .blog-empty {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 48px 32px;
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }
  .blog-empty h2 {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 22px;
    color: #0f172a;
    margin: 0 0 16px;
  }
  .blog-empty p {
    font-size: 15px;
    line-height: 1.6;
    color: #475569;
    margin: 0 0 12px;
  }
  .blog-empty a { color: #4F46E5; text-decoration: underline; }

  .blog-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }

  .blog-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    overflow: hidden;
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
  }
  .blog-card:hover {
    transform: translateY(-2px);
    border-color: #c7d2fe;
    box-shadow: 0 12px 24px rgba(15, 23, 42, 0.06);
  }
  .blog-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 24px;
    color: inherit;
    text-decoration: none;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }
  .blog-card-category {
    background: #eef2ff;
    color: #4F46E5;
    padding: 2px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .blog-card-new {
    background: #dcfce7;
    color: #166534;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
  }

  .blog-card-title {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 19px;
    line-height: 1.3;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }
  .blog-card-desc {
    font-size: 14px;
    line-height: 1.55;
    color: #475569;
    margin: 0 0 20px;
    flex-grow: 1;
  }
  .blog-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: #94a3b8;
  }
  .blog-card-arrow {
    color: #4F46E5;
    font-weight: 600;
    transition: transform 0.15s;
  }
  .blog-card:hover .blog-card-arrow {
    transform: translateX(3px);
  }
</style>
