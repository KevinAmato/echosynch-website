---
// Site-wide layout. Wraps every page in:
//   - <head> with consistent meta + OG tags
//   - The sticky nav
//   - <main> for page content (passed via <slot />)
//   - The footer
//
// Per-page overrides:
//   - title           → <title> + OG title
//   - description     → meta description + OG description
//   - canonical       → optional canonical URL (defaults to the current path)
//   - ogImage         → optional OG image URL (defaults to /og-image.png)
//   - activeNav       → which nav item to highlight
//   - bodyClass       → optional extra class on <body> for page-specific bg
//
// Why a single layout: Slack Directory review confirms that privacy/terms/
// support/etc. are reachable from the landing page footer. If those pages
// use a different chrome (or have NO chrome), reviewers ding the listing.
// One layout = one footer = one promise to reviewers.

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WaitlistModal from '../components/WaitlistModal.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  activeNav?: 'product' | 'pricing' | 'compare' | 'docs' | null;
  bodyClass?: string;
}

const {
  title = 'Echo-Synch — Slack-native IT triage with AI labels & SLAs',
  // Description capped at ~160 chars (Google's display limit). Anything
  // longer gets truncated with an ellipsis in SERP, hurting CTR.
  description = 'Slack-native IT triage. AI labels every request, SLA timers chase deadlines, full web dashboard. €12/agent/month — cancel anytime.',
  canonical,
  ogImage = '/og-image.png',
  activeNav = null,
  bodyClass = '',
} = Astro.props;

const SITE = 'https://echo-synch.com';
const url = canonical ?? new URL(Astro.url.pathname, SITE).toString();
const fullOgImage = ogImage.startsWith('http') ? ogImage : SITE + ogImage;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />

  <!-- Robots: explicitly allow indexing on the public site. Even though
       this is the default, declaring it shuts down any third-party tool
       that warns about "missing robots directive". -->
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />

  <!-- Theme color: tints mobile-browser chrome (Chrome address bar on
       Android, Safari status bar on iOS) with our brand indigo. -->
  <meta name="theme-color" content="#4F46E5" />

  <!-- Favicons. The PNG works as a 16/32/64; modern browsers pick the right
       size. We don't ship a 16x16 ICO because it's lossy at our logo size. -->
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />

  <!-- Fonts. Inter for UI, JetBrains Mono for code/eyebrows/Slack mocks.
       Preconnect saves ~100ms on first paint. font-display: swap so users
       don't see invisible text during font load. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
    rel="stylesheet"
  />

  <!-- Open Graph / Twitter. og:site_name lets Facebook/LinkedIn render
       a brand name above the link card. og:locale is explicit (default
       en_US is correct but Facebook docs recommend declaring it). -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={fullOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Echo-Synch — Slack-native IT triage" />
  <meta property="og:site_name" content="Echo-Synch" />
  <meta property="og:locale" content="en_US" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullOgImage} />
  <meta name="twitter:image:alt" content="Echo-Synch — Slack-native IT triage" />

  <!-- Schema.org SoftwareApplication. Slack Directory + Google look at
       this to render a richer search result with price + brand. We
       declare both Pro and Enterprise tiers as separate Offers so a
       price-range chip can show "€12-€22 / agent / month" in SERPs. -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Echo-Synch',
    applicationCategory: 'BusinessApplication',
    applicationSubCategory: 'IT Service Management',
    operatingSystem: 'Web, Slack',
    image: SITE + '/og-image.png',
    description,
    url: SITE,
    // Price-per-tier as flat Offers. We previously nested a
    // UnitPriceSpecification inside each Offer to express "per agent
    // per month" semantics, but Google's Rich Results validator
    // rejected the doubled price/priceCurrency (one at Offer level,
    // one inside priceSpecification) as "Invalid object type for
    // field priceSpecification". Their spec wants a single source of
    // truth; redundancy fails validation. We keep only the flat
    // shape, which Google's own SoftwareApplication example uses.
    // The "per agent / month" qualifier is communicated to search
    // engines via the priceCurrency + the free-text in the offer's
    // surrounding page content (the pricing-card body).
    offers: [
      {
        '@type': 'Offer',
        name: 'Pro',
        price: '12',
        priceCurrency: 'EUR',
      },
      {
        '@type': 'Offer',
        name: 'Enterprise',
        price: '22',
        priceCurrency: 'EUR',
      },
    ],
    publisher: {
      '@type': 'Organization',
      name: 'Echo-Synch',
      url: SITE,
      logo: SITE + '/echo-synch.svg',
      sameAs: [
        'https://thread-patrol.com',
      ],
    },
  })} />

  <!-- Organization-level entity. Separate from the SoftwareApplication
       above because Google treats them as different knowledge-graph
       nodes — a publisher can have multiple products.

       We deliberately omit `address` entirely rather than declare a
       partial PostalAddress with only country + locality. Google's
       Rich Results validator flags missing postalCode + streetAddress
       as "optional but recommended"; declaring a partial address gets
       a yellow warning AND no schema benefit. Cleaner to skip the
       field until we publish a real registered office address. -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Echo-Synch',
    url: SITE,
    logo: SITE + '/echo-synch.svg',
    email: 'support@echo-synch.com',
    contactPoint: {
      '@type': 'ContactPoint',
      email: 'support@echo-synch.com',
      contactType: 'customer support',
      availableLanguage: 'English',
    },
  })} />
</head>
<body class={bodyClass}>
  <Nav active={activeNav} />
  <main>
    <slot />
  </main>
  <Footer />

  {/* Singleton waitlist modal — triggered by every [data-waitlist] CTA on
      every page. Shipped here because adding it per-page would duplicate
      the script + its event handlers. */}
  <WaitlistModal />
</body>
</html>
